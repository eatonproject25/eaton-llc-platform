# Copy this file and rename it to .env
# Never commit your actual .env file — it is listed in .gitignore

# --- API Base URL ---
# Uncomment ONE of the following based on your development setup:

# Android emulator → host machine (most common for emulator dev)
# EXPO_PUBLIC_API_BASE_URL=http://10.0.2.2:8000/api

# Physical Android device on the same WiFi as your dev machine
# Find your machine's local IP with `ipconfig` (Windows) or `ifconfig` (Mac/Linux)
# Make sure the device and machine are on the same network
# EXPO_PUBLIC_API_BASE_URL=http://192.168.1.x:8000/api

# Start the Django backend with:
# python manage.py runserver 0.0.0.0:8000